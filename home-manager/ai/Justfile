# Description: Show all available constitution items and skills
list:
    @find constitutions skills -name "*.md" | sort

# Description: Interactively select constitution items and skills, then copy them with
# version frontmatter to <target>. Always writes AGENTS.md from templates/entrypoint.md
# as the canonical AI entrypoint. Vendor stubs (CLAUDE.md, GEMINI.md, etc.) are thin
# redirects to AGENTS.md — defaults come from config/vendors.yaml.
# Requires gum (https://github.com/charmbracelet/gum) and yq.
marshal target:
    @just_scripts/marshal.sh "{{target}}"
